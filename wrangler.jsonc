{
  // Cloudflare Pages — static site config
  // Deploy with: npx wrangler pages deploy .
  // R2 binding (DATA_BUCKET → cert-study-data) is configured in the CF Pages
  // dashboard: Settings → Functions → R2 bucket bindings. Do not add r2_buckets
  // here — Pages does not support that key and it will break deployment.
  "name": "cert-study-guides",
  "pages_build_output_dir": ".",
  "compatibility_date": "2025-01-01"
}
